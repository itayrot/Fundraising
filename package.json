  "version": "1.0.0",
  "description": "Monthly donations integration between Hyp and Monday.com",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
