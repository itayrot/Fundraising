# PostgreSQL connection string
DATABASE_URL=postgresql://donations:CHANGE_ME@localhost:5432/donations

# Monday.com API token (Admin → Developers → API Token)
MONDAY_API_KEY=CHANGE_ME

# Monday.com Board ID (from the board URL: monday.com/boards/<ID>)
MONDAY_MASTER_BOARD_ID=CHANGE_ME

# Monday.com Column IDs for the master donations board
# Right-click any column header → "Column Settings" → copy the ID
MONDAY_COL_EMAIL=email
MONDAY_COL_FIRST_DATE=date4
MONDAY_COL_LAST_DATE=date
MONDAY_COL_AMOUNT=numbers
MONDAY_COL_CURRENCY=dropdown
MONDAY_COL_PLATFORM=dropdown7
MONDAY_COL_STATUS=status

# Server port
PORT=3000
