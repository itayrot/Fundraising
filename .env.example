# DigitalOcean Managed Postgres connection string
DATABASE_URL=postgresql://user:password@host:25060/dbname?sslmode=require

# Monday.com API token (from monday.com > Profile > Developers > API)
MONDAY_API_KEY=your_monday_api_token

# Monday Board IDs (numeric IDs from the board URL)
MONDAY_MASTER_BOARD_ID=1234567890

# Monday column IDs — fill in AFTER creating the boards
# To find column IDs: open board > right-click column header > "Column Settings" > shows ID
MONDAY_COL_EMAIL=email
MONDAY_COL_FIRST_DATE=date4
MONDAY_COL_LAST_DATE=date5
MONDAY_COL_AMOUNT=numbers
MONDAY_COL_CURRENCY=dropdown
MONDAY_COL_PLATFORM=dropdown0
MONDAY_COL_STATUS=status

# Hyp webhook secret (from Hyp dashboard — used to validate incoming webhooks)
HYP_WEBHOOK_SECRET=your_hyp_webhook_secret

# Random secret to protect the cron endpoint from unauthorized calls
CRON_SECRET=generate_a_random_string_here

PORT=3000
